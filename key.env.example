# STEM Tutor Agent 配置示例
# 复制此文件为 key.env 并填入实际值

# === 基础配置 ===
STEM_TUTOR_PROVIDER=openai-compatible
STEM_TUTOR_SUBJECT=calculus

# === API 配置 ===
PARATERA_API_KEY=your-api-key-here
PARATERA_URL=https://openrouter.ai/api/v1

# === 模型配置 ===
STEM_TUTOR_REASONING_MODEL=qwen/qwen3.6-plus
STEM_TUTOR_FAST_MODEL=deepseek/deepseek-v3.2
STEM_TUTOR_OCR_MODEL=qwen/qwen3.6-plus
STEM_TUTOR_BASELINE_GLM5_MODEL=qwen/qwen3-30b-a3b-instruct-2507
STEM_TUTOR_BASELINE_KIMI_MODEL=qwen/qwen3-30b-a3b-instruct-2507
STEM_TUTOR_DETECTION_MODEL=qwen/qwen3-30b-a3b-instruct-2507

# === 分析深度 ===
STEM_TUTOR_DEPTH=standard

# === 功能开关 ===
STEM_TUTOR_SYMPY_ENABLED=true
STEM_TUTOR_TOOL_CALLING=false
STEM_TUTOR_DUAL_MODEL=false
STEM_TUTOR_SIMPLE_FASTPATH=true
STEM_TUTOR_DETERMINISTIC_VERIFY=true

# === 超时与重试 ===
STEM_TUTOR_TIMEOUT=300
STEM_TUTOR_MAX_RETRIES=1
STEM_TUTOR_ALLOW_MOCK_FALLBACK=true
